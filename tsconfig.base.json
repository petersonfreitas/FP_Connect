{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@fp/config": ["packages/config/src/index.ts"],
      "@fp/shared": ["packages/shared/src/index.ts"],
      "@fp/types": ["packages/types/src/index.ts"]
    }
  }
}
