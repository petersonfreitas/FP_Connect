NODE_ENV=development
PORT=3001

# Internal server-to-server API token used by FP frontends and jobs.
FP_INTERNAL_API_TOKEN=change-me-use-a-long-random-token
FP_API_INTERNAL_URL=http://localhost:3001/api
FP_CNPJ_LOOKUP_BASE_URL=https://brasilapi.com.br/api/cnpj/v1
FP_CNPJ_LOOKUP_USER_AGENT=FP-Connect/0.1 (+https://github.com/petersonfreitas/FP_Connect)
FP_WEB_URL=http://localhost:3000

# Supabase server-side credentials.
# SUPABASE_ANON_KEY is used by the Next server for Supabase Auth login.
# Never expose SUPABASE_SERVICE_ROLE_KEY in frontend/browser code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Mercado Pago OAuth app credentials.
# Configure the app redirect URL as: ${FP_WEB_URL}/gateway/mercado-pago/callback
MERCADO_PAGO_CLIENT_ID=your-mercado-pago-client-id
MERCADO_PAGO_CLIENT_SECRET=your-mercado-pago-client-secret
