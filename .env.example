NODE_ENV=development
PORT=3001

# Internal server-to-server API token used by FP frontends and jobs.
FP_INTERNAL_API_TOKEN=change-me-use-a-long-random-token
FP_API_INTERNAL_URL=http://localhost:3001/api

# Supabase server-side credentials. Never expose the service role key in frontend code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
